rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() && (
        request.auth.token.email in ['admin@gamingactions.com', 'pdiop08@outlook.fr', 'free08man@gmail.com']
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }
    function notBanned() {
      return !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('banned', false);
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Lecture publique : leaderboard web (champs non sensibles : username, avatar, ggReceived, plan, isChampion, streakLevel)
    // Lecture auth   : profil complet (app mobile)
    // Écriture : uniquement son propre profil OU admin
    match /users/{userId} {
      allow read: if true; // lecture publique pour leaderboard web + app
      allow create: if isOwner(userId);
      // Seul l'owner ou un admin peut mettre à jour son profil.
      // ownedVideoFrames peut être mis à jour par tout user auth (attribution de frame via achat).
      allow update: if isOwner(userId) || isAdmin()
        || (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownedVideoFrames']));
    }

    // ── Videos ───────────────────────────────────────────────────────────────
    match /videos/{videoId} {
      allow read: if true; // lecture publique pour leaderboard web + feed app
      allow create: if isAuth() && notBanned() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // ── GGs ──────────────────────────────────────────────────────────────────
    // Un GG ne peut être créé/mis à jour que par son propriétaire (userId == auth.uid)
    match /ggs/{ggId} {
      allow read: if isAuth();
      allow create: if isAuth() && notBanned()
        && request.resource.data.userId == request.auth.uid;
      // allow update : sécurité si setDoc appelé sur un doc existant (idempotent)
      allow update: if isAuth() && notBanned()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.userId == request.auth.uid;
    }

    // ── Follows ──────────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth() && notBanned()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.followerId == request.auth.uid;
    }

    // ── Comments ─────────────────────────────────────────────────────────────
    // Lecture publique — les visiteurs voient les commentaires dans le feed
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.userId == request.auth.uid;
      // Seuls le texte et les likes/likedBy sont modifiables — empêche injection isChampion etc.
      allow update: if isAuth() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['text', 'likes', 'likedBy', 'edited', 'editedAt']);
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    match /tipComments/{commentId} {
      allow read: if true;
      allow create: if isAuth() && notBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }

    // ── Points history ────────────────────────────────────────────────────────
    // Lecture : user voit uniquement son historique
    // Écriture : user peut créer ses propres entrées (daily login, achats shop)
    //            Admin peut tout modifier (corrections)
    match /points_history/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Fanbase ───────────────────────────────────────────────────────────────
    match /fanbase_subscriptions/{subId} {
      allow read: if isAuth();
      allow create: if isAuth() && notBanned()
        && request.resource.data.subscriberId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.subscriberId == request.auth.uid
        || resource.data.creatorId == request.auth.uid
        || isAdmin()
      );
    }

    // ── Gift cards (create = user, update = admin only) ───────────────────────
    match /gift_card_requests/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && notBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Earnings & withdrawals ────────────────────────────────────────────────
    // creator_earnings : le user peut lire son propre doc et mettre à jour
    // balance/pendingWithdrawal lors d'une demande de retrait.
    // subscriberCount et totalEarned restent admin-only.
    match /creator_earnings/{creatorId} {
      allow read: if isOwner(creatorId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(creatorId) || isAdmin();
    }

    match /withdrawal_requests/{docId} {
      allow read: if isAuth() && resource.data.creatorId == request.auth.uid;
      allow create: if isAuth()
        && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Subscriptions (géré par RevenueCat + Admin SDK) ───────────────────────
    match /subscriptions/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && notBanned();
      allow update, delete: if isAdmin();
    }

    // ── Thanks ────────────────────────────────────────────────────────────────
    match /thanks/{thankId} {
      allow read: if isAuth();
      allow create: if isAuth() && notBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Bells ─────────────────────────────────────────────────────────────────
    match /bells/{bellId} {
      allow read: if isAuth() && resource.data.bellerId == request.auth.uid;
      allow create: if isAuth();
      allow delete: if isAuth() && resource.data.bellerId == request.auth.uid;
    }

    // ── Creator requests ──────────────────────────────────────────────────────
    match /creator_requests/{reqId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() && notBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Custom games (read all, create par user pour upload, update/delete admin) ──
    match /custom_games/{gameId} {
      allow read: if isAuth();
      allow create: if isAuth() && notBanned();
      allow update, delete: if isAdmin();
    }

    // ── App config (read all auth, write admin only) ──────────────────────────
    match /app_config/{configId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── System — écriture admin uniquement ──────────────────────────────────────
    match /system/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Username reservation ──────────────────────────────────────────────────
    match /username/{usernameId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Bug reports ───────────────────────────────────────────────────────────
    match /bug_reports/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    // ── Logging (write-only pour les users, read admin) ───────────────────────
    match /errorLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    match /appLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    match /errorCounters/{docId} {
      allow read: if isAdmin();
      allow write: if isAuth();
    }

    // ── Fanbases (metadata créateur) ─────────────────────────────────────────────
    match /fanbases/{creatorId} {
      allow read: if isAuth();
      allow create, update: if isOwner(creatorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── FanBox messages ───────────────────────────────────────────────────────
    // Abonnés + créateur peuvent lire et écrire.
    // Soft-delete (update deleted:true) : auteur du msg OU créateur.
    match /fanbox_messages/{creatorId}/messages/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth() && notBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid
        || request.auth.uid == creatorId
      );
      allow delete: if isAdmin();
    }

    // ── FanBox mutes ──────────────────────────────────────────────────────────
    // Seul le créateur (ou admin) peut écrire un mute.
    // L'user muté peut lire son propre doc pour afficher la bannière.
    match /fanbox_mutes/{muteId} {
      allow read: if isAuth();
      allow write: if isAuth() && (
        request.resource.data.creatorId == request.auth.uid || isAdmin()
      );
    }

    // ── Moderation ────────────────────────────────────────────────────────────
    match /moderation_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }

    match /moderation_counters/{userId} {
      allow read: if isAdmin();
      allow write: if isAuth();
    }
  }
}

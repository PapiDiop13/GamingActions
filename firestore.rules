rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utilisateurs authentifiés : accès standard ──
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /ggs/{ggId} {
      allow read, write: if request.auth != null;
    }

    match /follows/{followId} {
      allow read, write: if request.auth != null;
    }

    match /comments/{commentId} {
      allow read, write: if request.auth != null;
    }

    match /tipComments/{commentId} {
      allow read, write: if request.auth != null;
    }

    match /points_history/{docId} {
      allow read, write: if request.auth != null;
    }

    match /creator_requests/{reqId} {
      allow read, write: if request.auth != null;
    }

    match /moderation_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    match /moderation_counters/{userId} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }

    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }

    match /thanks/{thankId} {
      allow read, write: if request.auth != null;
    }

    match /bells/{bellId} {
      allow read, write: if request.auth != null;
    }

    match /fanbase_subscriptions/{subId} {
      allow read, write: if request.auth != null;
    }

    match /custom_games/{gameId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /app_config/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /username/{usernameId} {
      allow read, write: if request.auth != null;
    }

    match /bug_reports/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Logging & monitoring (nouvelles collections) ──
    match /errorLogs/{docId} {
      allow read, write: if request.auth != null;
    }

    match /appLogs/{docId} {
      allow read, write: if request.auth != null;
    }

    match /errorCounters/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Feed session tracking ──
    // (géré localement via AsyncStorage, pas de collection Firestore)

  }
}
